# Environment variables (optional, overrides config.yaml if set)

# Scraper settings
SCRAPER_MAX_PAGES=50
SCRAPER_CONCURRENCY=5
SCRAPER_REQUEST_DELAY=1.0
SCRAPER_REQUEST_JITTER=0.5
SCRAPER_TIMEOUT=10
SCRAPER_RETRY_ATTEMPTS=3

# Database
DATABASE_PATH=data/books.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# API & Frontend (internal use)
API_BASE_URL=http://backend:8000/api/v1